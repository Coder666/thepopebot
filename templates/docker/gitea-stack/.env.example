# ── Gitea ──────────────────────────────────────────────────────────────────
# The public-facing domain/hostname of your Gitea instance.
GITEA_DOMAIN=localhost

# Full root URL that Gitea uses for clone URLs and redirects.
GITEA_URL=http://localhost:3000

# Ports exposed on the host.
GITEA_HTTP_PORT=3000
GITEA_SSH_PORT=2222

# Random secret for Gitea's internal encryption — change before first run.
GITEA_SECRET_KEY=changeme-generate-a-real-64-char-secret-here

# ── Gitea Actions Runner ────────────────────────────────────────────────────
# Registration token from: Gitea UI → Site Administration → Actions → Runners
# Or: docker compose exec gitea gitea actions generate-runner-token
GITEA_RUNNER_TOKEN=

# Display name for this runner (shown in the Gitea UI).
GITEA_RUNNER_NAME=popebot-runner

# ── thepopebot event handler ────────────────────────────────────────────────
# Port to expose thepopebot on the host.
THEPOPEBOT_PORT=3001

# Path to your thepopebot project directory (contains config/, skills/, .env).
# Defaults to ./project (create it with: npx thepopebot init)
THEPOPEBOT_PROJECT_DIR=./project

# ── thepopebot project .env values (written into THEPOPEBOT_PROJECT_DIR/.env)
# These are also set by setup-gitea.mjs. Shown here for reference.
#
# APP_URL=http://localhost:3001
# AUTH_SECRET=<random>
# GH_WRAPPER_BACKEND=gitea
# GITEA_URL=http://localhost:3000
# GITEA_TOKEN=<your-gitea-PAT>
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_API_KEY=<your-key>
